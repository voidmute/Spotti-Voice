# Spotti Voice — desktop app (public repo)
# Copy to voice-pill/.env for local dev only. End users sign in via Discord; no API keys here.

# Cloud STT proxy base URL (TLS). Override for staging only.
SPOTTI_VOICE_API_BASE=https://spotti.family

# Optional: force a specific .env path (dev)
# SPOTTI_VOICE_ENV_FILE=

# Local whisper model cache (default: %APPDATA%\SpottiVoice\models)
# SPOTTI_VOICE_MODELS_DIR=
