<html>
<head>
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<title>Spotti Voice</title>
<HTA:APPLICATION
  ID="SpottiVoiceSplash"
  APPLICATIONNAME="Spotti Voice"
  BORDER="none"
  CAPTION="no"
  SHOWINTASKBAR="no"
  SCROLL="no"
  SINGLEINSTANCE="yes"
  SYSMENU="no"
  CONTEXTMENU="no"
  SELECTION="no"
/>
<style>
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: transparent;
  }
  .spinner {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 26px;
    height: 26px;
    margin: -13px 0 0 -13px;
    border-radius: 50%;
    border: 2.5px solid rgba(255, 255, 255, 0.18);
    border-top-color: #ffffff;
    box-sizing: border-box;
    animation: spin 0.85s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
<script>
(function () {
  var w = 40;
  var h = 40;
  resizeTo(w, h);
  moveTo(Math.round((screen.width - w) / 2), Math.round((screen.height - h) / 2));

  var shell = new ActiveXObject("WScript.Shell");
  var env = shell.Environment("PROCESS");
  var temp = env("TEMP");
  var stopPath = temp + "\\SpottiVoice-splash.stop";
  var ownerPid = env("SPOTTI_SPLASH_OWNER") || "";
  var fso = new ActiveXObject("Scripting.FileSystemObject");

  try {
    fso.DeleteFile(stopPath, true);
  } catch (e) {}

  setInterval(function () {
    try {
      if (fso.FileExists(stopPath)) {
        window.close();
        return;
      }
      if (ownerPid) {
        var wmi = GetObject("winmgmts:");
        var q = wmi.ExecQuery("SELECT ProcessId FROM Win32_Process WHERE ProcessId=" + ownerPid);
        if (q.Count === 0) {
          window.close();
        }
      }
    } catch (e) {}
  }, 100);
})();
</script>
</head>
<body>
  <div class="spinner" aria-hidden="true"></div>
</body>
</html>
