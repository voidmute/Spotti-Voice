<html>
<head>
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<title>Spotti Voice</title>
<HTA:APPLICATION
  ID="splash"
  APPLICATIONNAME="Spotti Voice"
  BORDER="none"
  CAPTION="no"
  SHOWINTASKBAR="no"
  SCROLL="no"
  SINGLEINSTANCE="yes"
  SYSMENU="no"
  CONTEXTMENU="no"
  SELECTION="no"
/>
<style>
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: transparent;
  }
  .stage {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: rgba(10, 10, 16, 0.78);
  }
  .spinner {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.14);
    border-top-color: #ffffff;
    animation: spin 0.85s cubic-bezier(0.45, 0.05, 0.25, 0.95) infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .spinner {
      animation-duration: 1.4s;
    }
  }
</style>
<script>
  (function () {
    var w = 72;
    var h = 72;
    resizeTo(w, h);
    moveTo(Math.round((screen.width - w) / 2), Math.round((screen.height - h) / 2));
  })();
</script>
</head>
<body>
  <div class="stage" aria-hidden="true">
    <div class="spinner"></div>
  </div>
</body>
</html>
